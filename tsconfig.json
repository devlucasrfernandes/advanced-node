{
  "compilerOptions": {
    /* --- Output & Pathing --- */
    "outDir": "dist", // Destino dos arquivos compilados.
    "rootDir": "src", // Pasta raiz do código fonte.
    "baseUrl": ".", // Base para caminhos não-relativos.
    "paths": {
      // Atalhos (aliases) de pastas.
      "@/*": ["src/*"],
      "@/tests/*": ["tests/*"]
    },

    /* --- Compilation Target --- */
    "target": "es2022", // Versão do JavaScript de saída.
    "module": "commonjs", // Sistema de módulos (Node padrão).
    "moduleResolution": "node10", // Como o TS busca módulos no Node.

    /* --- Modernization & Compatibility --- */
    "ignoreDeprecations": "6.0", // Ignora avisos de recursos obsoletos no TS 6.
    "esModuleInterop": true, // Compatibilidade para importar CommonJS como ES6.
    "forceConsistentCasingInFileNames": true, // Padroniza maiúsculas/minúsculas entre sistemas.

    /* --- Strictness & Safety --- */
    "strict": true, // Ativa checagem rigorosa de tipos.
    "skipLibCheck": true, // Pula verificação de bibliotecas externas.
    "noEmit": true, // Não gera arquivos (usado apenas para lint/IDE).

    /* --- Node.js Environment --- */
    "types": ["node", "jest"] // Tipos globais para módulos nativos (ex: path).
  },

  /* --- Scope --- */
  "include": [
    "src", // Pasta de código incluída.
    "tests" // Pasta de testes incluída.
  ]
}
