{
  "name": "advanced-node",
  "version": "1.0.0",
  "description": "Projeto Node.js Avançado com Clean Architecture",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.js",
    "build": "rimraf dist && tsc -p tsconfig-build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --passWithNoTests --no-cache --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "Lucas Fernandes",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.1",
    "module-alias": "^2.3.4"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "22.x"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
